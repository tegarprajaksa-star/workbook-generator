// Prisma schema for Workbook / Business Process Generator
// Users create workbooks (employee manuals) for ANY position, aided by AI,
// then export to PPTX or DOCX.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTHENTICATION
// ============================================================

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         String    @default("USER") // ADMIN | USER
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions  Session[]
  workbooks Workbook[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================================
// WORKBOOK — one complete employee manual for one position
// ============================================================

model Workbook {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String // e.g. "Buku Kerja Karyawan Barista"
  companyName     String   @default("")
  companyTagline  String   @default("")
  positionTitle   String // e.g. "Barista"
  department      String   @default("")
  reportsTo       String   @default("")
  subordinates    String   @default("")
  purpose         String   @default("") // Tujuan Jabatan
  authority       String   @default("") // Wewenang (newline-separated)
  responsibilities String  @default("") // Tanggung Jawab (newline-separated)
  dutiesPrimary   String   @default("")
  dutiesDaily     String   @default("")
  dutiesWeekly    String   @default("")
  dutiesMonthly   String   @default("")
  krasJson        String   @default("[]") // JSON array
  status          String   @default("DRAFT") // DRAFT | PUBLISHED
  accentColor     String   @default("#b45309")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  processes WorkbookProcess[]

  @@index([userId])
}

model WorkbookProcess {
  id          String   @id @default(cuid())
  workbookId  String
  workbook    Workbook @relation(fields: [workbookId], references: [id], onDelete: Cascade)
  code        String // P01, P02...
  name        String
  description String   @default("")
  inputText   String   @default("")
  outputText  String   @default("")
  totalSla    String   @default("")
  category    String   @default("")
  lanesJson   String   @default("[]") // JSON array of lane names
  stepsJson   String   @default("[]") // JSON array of step objects
  sopsJson    String   @default("[]") // JSON array of SOP objects
  formsJson   String   @default("[]") // JSON array of form field objects
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workbookId])
}
